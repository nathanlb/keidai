{
  "name": "@torii/gateway",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "torii": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx --test 'src/**/tests/**/*.test.ts'",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@torii/shared": "workspace:*",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
