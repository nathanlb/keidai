    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@torii/shared": "workspace:*",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
