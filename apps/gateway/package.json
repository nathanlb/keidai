{
  "name": "@keidai/gateway",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "torii": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "torii": "tsx src/index.ts",
    "dev:inspect": "tsx scripts/run-mcp-inspector.ts",
    "test": "tsx --test 'src/**/tests/**/*.test.ts'",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@keidai/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "fastify": "^5.8.5",
    "jose": "^6.2.3",
    "reflect-metadata": "^0.2.2",
    "selfsigned": "^5.5.0",
    "tsyringe": "^4.10.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/node": "^22.20.0",
    "@types/selfsigned": "^2.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
