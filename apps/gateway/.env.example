# =============================================================================
# Torii gateway — copy to apps/gateway/.env
# Shared vars (e.g. DEMO_AGENT_BEARER) can live in the repo root .env instead.
# Do not commit .env.
# =============================================================================

TORII_CONFIG_PATH=./torii.demo.yaml
# TORII_PORT=3100
# TORII_HOST=127.0.0.1
# TORII_UI_CLIENT_ROOT=./path/to/keidai-ui/dist/client
# TORII_DB_PATH=./data/torii.db
# TORII_GATEWAY_BASE_URL=http://127.0.0.1:3100

LINEAR_API_KEY=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Production identity (not needed for local demo)
# TORII_K8S_SA_OIDC_ISSUER=
# TORII_K8S_SA_OIDC_AUDIENCE=
# TORII_K8S_SA_OIDC_JWKS_URI=

# Optional tracing
# OTEL_EXPORTER_OTLP_ENDPOINT=
