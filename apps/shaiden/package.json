{
  "name": "@keidai/shaiden",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx --test 'src/**/tests/**/*.test.ts'",
    "eval": "tsx --tsconfig tsconfig.eval.json --test 'eval/**/*.live.eval.ts'",
    "typecheck": "tsc -p tsconfig.check.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.109",
    "@keidai/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^5.0.205",
    "fastify": "^5.8.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
