{
  "name": "@keidai/keidai-ui",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "vite build && tsc -p tsconfig.server.json",
    "dev": "tsx server/dev.ts",
    "start": "node dist/server/index.js",
    "pretest": "pnpm run build",
    "test": "tsx --test 'server/tests/**/*.test.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "pnpm typecheck"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.5.0",
    "@fastify/static": "^8.3.0",
    "@keidai/ui": "workspace:*",
    "fastify": "^5.8.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^7.3.5"
  }
}
