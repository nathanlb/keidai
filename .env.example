# =============================================================================
# Shared dev secrets — copy to .env at the repo root.
# Loaded by all apps via loadEnvForPackage() before app-specific .env files.
# Do not commit .env.
# =============================================================================

# Used by gateway (torii.demo.yaml inbound_token) and demo-agent (Authorization header)
DEMO_AGENT_BEARER=change-me-to-a-long-random-string

# Used by Shaiden (Authorization header) and torii.demo.yaml inbound_token
SHAIDEN_BEARER=change-me-to-a-long-random-string
